{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PulseDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "CHANGE-THIS-TO-A-SECURE-KEY-AT-LEAST-32-CHARS!!",
